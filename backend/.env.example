# LLM Provider (required - pick one)
OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# LLM Settings
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o             # or claude-sonnet-4-20250514
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Agent Identity
AGENT_NAME=Atlas
AGENT_PERSONALITY=personality.txt

# WhatsApp Channel (optional - leave blank to disable)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=      # e.g. whatsapp:+14155238886
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Memory
MEMORY_AUTO_CAPTURE=true
MEMORY_AUTO_RECALL=true
MEMORY_WORKSPACE=./data/workspace
EMBEDDING_PROVIDER=openai     # openai | local
